# .env.example - Example environment variables for Nascent-NepalUS backend
# Copy this to `.env` and fill sensitive values before running in Docker or locally.
# DO NOT commit your real `.env` to version control.

###########
# Database (Postgres)
###########
# Used by docker-compose and Django settings. Defaults are safe for local dev only.
POSTGRES_DB=nascent
POSTGRES_USER=nascent
POSTGRES_PASSWORD=nascentpassword
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Alias names accepted by settings (optional; settings prefers POSTGRES_* but will read DATABASE_* as fallback)
DATABASE_NAME=${POSTGRES_DB}
DATABASE_USER=${POSTGRES_USER}
DATABASE_PASSWORD=${POSTGRES_PASSWORD}
DATABASE_HOST=${POSTGRES_HOST}
DATABASE_PORT=${POSTGRES_PORT}

###########
# Django core
###########
# SECRET_KEY must be set to a secure random value in production
SECRET_KEY=changeme-insecure-secret-for-dev

# DEBUG: set to 0 or false in production
DEBUG=1

# Comma-separated allowed hosts (e.g., example.com,api.example.com). Defaults include localhost for dev.
ALLOWED_HOSTS=localhost,127.0.0.1

# Timezone
TIME_ZONE=UTC

# Django settings module (adjust if your project package name differs)
# For this repo the project package is `config` (settings in backend/config/settings.py)
DJANGO_SETTINGS_MODULE=config.settings

###########
# Docker / Compose helpers (optional)
###########
# Port mapping used by compose (override if necessary)
POSTGRES_PORT=5432
